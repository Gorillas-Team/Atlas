{
    "rules": {
        "quotes": [
            "error",
            "single"
        ],
        "semi": [
            "error",
            "never"
        ],
        "indent": [
            "warn",
            2
        ]
    },
    "parserOptions": {
        "ecmaVersion": 2018
    },
    "env": {
        "node": true
    }
}