{
	"name": "atlas",
	"version": "0.0.1",
	"description": "Discord music bot focused on high sound quality",
	"main": "index.js",
	"scripts": {
		"start": "eslint . && node -r dotenv/config .",
		"dev": "eslint . && nodemon",
		"fix": "eslint --fix .",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coveralls": "jest --coverage && coveralls < coverage/lcov.info"
