{
  "name": "atlasbot",
  "packageManager": "yarn@3.3.1",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/*",
      "app"
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "test": "ava",
    "test:watch": "ava --watch",
    "test:cov": "c8 -x \"{.pnp.cjs,.pnp.loader.mjs}\" --src \"{app,packages}\" -r lcov --check-coverage ava",
    "coveralls": "coveralls < coverage/lcov.info"
  },
  "devDependencies": {
    "ava": "^5.2.0",
    "c8": "^7.13.0",
    "coveralls": "^3.1.1",
    "eslint": "^8.0.1",
    "eslint-config-standard": "latest",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-n": "^15.0.0",
    "eslint-plugin-promise": "^6.0.0"
  }
}
