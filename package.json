	"bugs": {
		"url": "https://github.com/Gorillas-Team/Atlas/issues"
	},
	"homepage": "https://github.com/Gorillas-Team/Atlas#readme",
	"devDependencies": {
		"coveralls": "^3.1.0",
		"dotenv": "^8.2.0",
		"eslint": "^6.8.0",
		"jest": "^25.5.3",
		"nodemon": "^2.0.3"
	},
	"dependencies": {
		"discord.js": "^12.2.0"
	}
}
